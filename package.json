{
  "name": "watering-api",
  "version": "1.0.0",
  "private": true,
  "description": "Modular TypeScript API starter for watering-api",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "mysql2": "^3.19.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22.13.13",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
